# Copy this file to .env and fill in your own values.

# A Postgres connection string. Get a free one from neon.tech, supabase.com,
# or Vercel's own Postgres storage add-on when you deploy.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Optional: set these to send real OTP login emails via Resend (resend.com,
# free tier available). Leave unset for local/dev use — the login code is
# shown directly on the verify page instead of being emailed.
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="login@yourdomain.com"

# Optional: set this to store photos in Vercel Blob storage (enable "Blob"
# under Storage in your Vercel project — it auto-fills this var when linked
# with `vercel env pull`). Leave unset for local/dev use — photos are saved
# to public/uploads/finds/ on disk instead.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
