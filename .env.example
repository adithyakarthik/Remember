# Copy this file to .env and fill in your own values.

# A Postgres connection string. Get a free one from neon.tech, supabase.com,
# or Vercel's own Postgres storage add-on when you deploy.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Optional: set these to send real OTP login emails via Resend (resend.com,
# free tier available). Leave unset for local/dev use — the login code is
# shown directly on the verify page instead of being emailed.
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="login@yourdomain.com"

# Optional: set this to store photos in Vercel Blob storage (enable "Blob"
# under Storage in your Vercel project — it auto-fills this var when linked
# with `vercel env pull`). Leave unset for local/dev use — photos are saved
# to public/uploads/finds/ on disk instead.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Optional: "Continue with Google" sign-in. Create an OAuth client at
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth
# client ID (type: Web application). Add these authorized redirect URIs:
#   http://localhost:3001/api/auth/google/callback   (local)
#   https://your-app.vercel.app/api/auth/google/callback   (production)
# Leave unset to hide the Google button and use email login only.
# GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="xxxxx"
# GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/auth/google/callback"  # only if you need to pin it

# Optional: paid Pro subscriptions via Razorpay (razorpay.com). Create a
# monthly Subscription Plan in the Razorpay dashboard, then set the keys below.
# Add a webhook pointing to /api/billing/webhook subscribed to the
# subscription.* events, and put its secret in RAZORPAY_WEBHOOK_SECRET.
# Leave unset and the Upgrade page shows "coming soon" (free plan still works).
# RAZORPAY_KEY_ID="rzp_live_xxx"
# RAZORPAY_KEY_SECRET="xxx"
# RAZORPAY_PLAN_ID="plan_xxx"
# RAZORPAY_WEBHOOK_SECRET="xxx"
